# Optional — inquiry delivery
# Path A (recommended): Resend email  https://resend.com
RESEND_API_KEY=
INQUIRY_TO_EMAIL=you@company.com
# Must be a verified domain sender in production. Resend test sender works only to your signup email:
# INQUIRY_FROM_EMAIL=Inquiry <onboarding@resend.dev>
INQUIRY_FROM_EMAIL=

# Path B: forward JSON to any webhook (Make / Zapier / 企微中转 / n8n)
INQUIRY_WEBHOOK_URL=

# Public form config
NEXT_PUBLIC_SITE_ID=nextjs-export-starter
NEXT_PUBLIC_INQUIRY_ENDPOINT=/api/inquiries

# Optional — Sanity CMS (only needed if you use scripts/pull-from-sanity.mjs)
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_TOKEN=
